# RapidAPI
RAPIDAPI_KEY=your_rapidapi_key_here

# ---- Database ----
# 本地开发（需先运行 bash scripts/start-rds-tunnel.sh）：
#   DB_HOST=127.0.0.1
#   DB_PORT=3307
#
# 服务器部署（同 VPC 直连 RDS）：
#   DB_HOST=database-test.chomyssgs2p8.ap-southeast-1.rds.amazonaws.com
#   DB_PORT=3306

DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=gurryshark
DB_PASSWORD=
DB_NAME=gurysk_src

# ---- SSH Tunnel (可选，Python sshtunnel 自动建隧道) ----
